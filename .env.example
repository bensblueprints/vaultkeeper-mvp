# --- Server ---
PORT=5323
ADMIN_PASSWORD=change-me-now

# Encrypts stored credentials (connection passwords, S3 keys, passphrases) at
# rest with AES-256-GCM. Auto-generated into .env on first run if missing.
# KEEP THIS SAFE — losing it means re-entering all stored secrets.
# SECRET_KEY=64-hex-chars

# --- Data ---
# DB_PATH=./data/vaultkeeper.db
# BACKUP_TMP_DIR=./data/tmp

# --- Alerts: email via your own SMTP (nodemailer) ---
# (Can also be configured in Settings — the UI values win.)
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=postmaster@example.com
# SMTP_PASS=secret
# SMTP_FROM=vaultkeeper@example.com
