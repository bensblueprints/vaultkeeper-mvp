{
  "name": "vaultkeeper",
  "version": "1.0.0",
  "description": "Scheduled, encrypted database backups you control. Postgres, MySQL, SQLite, MongoDB — dumped on a schedule, compressed, encrypted, shipped to local disk / S3 / FTP, pruned by retention policy. Pay once, own it forever.",
  "author": "Ben (bensblueprints)",
  "license": "MIT",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "node server/index.js",
    "postinstall": "node scripts/setup-native.js",
    "desktop": "electron .",
    "test": "node test/smoke.js",
    "dist": "electron-builder --win nsis"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/lib-storage": "^3.700.0",
    "basic-ftp": "^5.0.5",
    "better-sqlite3": "^12.2.0",
    "cookie-parser": "^1.4.7",
    "cron-parser": "^4.9.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "nodemailer": "^6.9.16"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "electron": "^33.4.0",
    "electron-builder": "^25.1.8",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.474.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.1.0",
    "vite": "^6.3.5"
  },
  "build": {
    "appId": "com.bensblueprints.vaultkeeper",
    "productName": "Vaultkeeper",
    "files": [
      "electron/**",
      "server/**",
      "scripts/vk-decrypt.js",
      "dist/**",
      "vendor/**",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "directories": {
      "output": "release"
    }
  }
}
